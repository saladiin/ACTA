# Public alpha production environment.
# Copy these names into the host's environment settings. Do not commit real values.

NODE_ENV=production
B5_SERVE_WEB=true
BASE_PATH=/
LOG_LEVEL=info

# Managed database connection string.
# Render Blueprint can set this automatically via fromDatabase.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Clerk production keys.
CLERK_SECRET_KEY=sk_live_xxx
CLERK_PUBLISHABLE_KEY=pk_live_xxx
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxx
VITE_CLERK_PROXY_URL=/api/__clerk

# Public alpha should use real auth, not temporary username auth.
B5_USERNAME_AUTH=false
B5_TEMP_USERNAME_AUTH=false
VITE_B5_USERNAME_AUTH=false

# Optional closed-alpha allowlist. Comma, semicolon, or whitespace separated.
# Entries can be Clerk user IDs, usernames, or account email addresses.
B5_ALLOWED_USERS=

# Set after the production URL is known, for example:
# B5_ALLOWED_ORIGINS=https://b5acta-public-alpha.onrender.com
B5_ALLOWED_ORIGINS=
